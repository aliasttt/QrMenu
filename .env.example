DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# reCAPTCHA (signup anti-bot) — get keys at https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# Stripe (use test keys for development)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_ANNUAL=price_xxx

# App download links (panel + public)
APP_ANDROID_URL=https://example.com/app.apk
APP_IOS_URL=https://apps.apple.com/app/id000000000
