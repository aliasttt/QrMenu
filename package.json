{
  "name": "qrmenu-saas-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./static/src/input.css -o ./static/dist/app.css --minify",
    "watch:css": "tailwindcss -i ./static/src/input.css -o ./static/dist/app.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"python manage.py runserver\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}
